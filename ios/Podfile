# 1. Подключаем системные скрипты Flutter (обязательно в начале)
id_path = File.join('..', 'Flutter', 'podhelper.rb')
if File.exist?(id_path)
  require id_path
else
  # Запасной путь для GitHub Actions
  load File.join(File.dirname(File.realpath(__FILE__)), '..', 'Flutter', 'podhelper.rb') rescue nil
end

# 2. Устанавливаем минимальную версию iOS 15.0 для Firebase
platform :ios, '15.0'

prepare_command = "node --version"

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # 3. Установка всех плагинов проекта (Supabase, Firebase, Signature и т.д.)
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

# 4. Финальная настройка перед компиляцией
post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # Принудительно выставляем 15.0 для каждой библиотеки внутри проекта
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # Отключаем Bitcode для стабильной сборки
      config.build_settings['ENABLE_BITCODE'] = 'NO'
    end
  end
end